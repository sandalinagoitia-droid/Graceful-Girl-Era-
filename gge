  {v:"Be strong and courageous. Do not be afraid; do not be discouraged, for the Lord your God will be with you wherever you go.",r:"Joshua 1:9"},
  {v:"Charm is deceptive and beauty is fleeting, but a woman who fears the Lord is to be praised.",r:"Proverbs 31:30"},
  {v:"The Lord your God is with you, the Mighty Warrior who saves. He will take great delight in you.",r:"Zephaniah 3:17"},
  {v:"Trust in the Lord with all your heart and lean not on your own understanding.",r:"Proverbs 3:5"},
  {v:"She opens her mouth with wisdom, and the teaching of kindness is on her tongue.",r:"Proverbs 31:26"},
  {v:"Your beauty should not come from outward adornment… rather it should be that of your inner self, the unfading beauty of a gentle and quiet spirit.",r:"1 Peter 3:3-4"},
  {v:"God is within her, she will not fall.",r:"Psalm 46:5"},
  {v:"Do not be anxious about anything, but in every situation present your requests to God. And the peace of God will guard your heart.",r:"Philippians 4:6-7"},
  {v:"You are altogether beautiful, my darling; there is no flaw in you.",r:"Song of Solomon 4:7"},
  {v:"Cast all your anxiety on Him because He cares for you.",r:"1 Peter 5:7"},
  {v:"The Lord directs the steps of the godly. He delights in every detail of their lives.",r:"Psalm 37:23"},
  {v:"Before I formed you in the womb I knew you, before you were born I set you apart.",r:"Jeremiah 1:5"},
];

let scrIdx = new Date().getDay() % SCRIPTURES.length;

function renderScripture(veEl, refEl, idx) {
  if(!veEl) return;
  veEl.textContent = '"' + SCRIPTURES[idx].v + '"';
  refEl.textContent = '— ' + SCRIPTURES[idx].r;
}
function nextScripture(){ scrIdx=(scrIdx+1)%SCRIPTURES.length; updateAllScriptures(); }
function prevScripture(){ scrIdx=(scrIdx-1+SCRIPTURES.length)%SCRIPTURES.length; updateAllScriptures(); }
function updateAllScriptures(){
