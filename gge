// ── GLITTER ──
const canvas=document.getElementById('gc');const ctx=canvas.getContext('2d');let pts=[];
function resize(){canvas.width=innerWidth;canvas.height=innerHeight;}
const colors=['rgba(255,255,255,','rgba(255,182,193,','rgba(255,105,180,','rgba(245,200,66,','rgba(255,220,240,','rgba(255,45,120,'];
function mkPt(){return{x:Math.random()*innerWidth,y:Math.random()*innerHeight,r:Math.random()*2.2+0.3,color:colors[Math.floor(Math.random()*colors.length)],a:Math.random()*0.8+0.1,vy:-(Math.random()*0.45+0.07),vx:(Math.random()-0.5)*0.2,phase:Math.random()*Math.PI*2,ts:Math.random()*0.025+0.005,shape:Math.random()>0.5?'diamond':'circle'};}
function drawDiamond(x,y,r){ctx.beginPath();ctx.moveTo(x,y-r*1.6);ctx.lineTo(x+r,y);ctx.lineTo(x,y+r*1.6);ctx.lineTo(x-r,y);ctx.closePath();}
function glitter(t){
  ctx.clearRect(0,0,canvas.width,canvas.height);
  pts.forEach(p=>{
    const a=p.a*(0.4+0.6*Math.sin(t*p.ts+p.phase));
    ctx.fillStyle=p.color+a+')';
    if(p.shape==='diamond')drawDiamond(p.x,p.y,p.r);
    else{ctx.beginPath();ctx.arc(p.x,p.y,p.r,0,Math.PI*2);}
    ctx.fill();
    p.y+=p.vy;p.x+=p.vx;
    if(p.y<-10){p.y=canvas.height+10;p.x=Math.random()*canvas.width;}
    if(p.x<-10||p.x>canvas.width+10)p.x=Math.random()*canvas.width;
  });
  requestAnimationFrame(glitter);
}
resize();addEventListener('resize',resize);
for(let i=0;i<200;i++)pts.push(mkPt());
requestAnimationFrame(glitter);
